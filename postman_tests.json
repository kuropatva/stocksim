    {
      "name": "DRAIN CHAOS",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Config — edit only if needed\r",
              "const URL = pm.collectionVariables.get(\"baseUrl\") + \"/wallets/w5/stocks/CHAOS\";\r",
              "const METHOD = \"POST\";\r",
              "const TOTAL_REQUESTS = 120;\r",
              "const CONCURRENCY = 20; // number of parallel workers\r",
              "const BODY = { type: \"buy\" };\r",
              "const HEADERS = { \"Content-Type\": \"application/json\" };\r",
              "\r",
              "// derived\r",
              "const ITERATIONS = Math.ceil(TOTAL_REQUESTS / CONCURRENCY);\r",
              "\r",
              "// stats\r",
              "let stats = { total: 0, success: 0, errors: {}, start: Date.now() };\r",
              "\r",
              "function sendOne() {\r",
              "  return new Promise((resolve) => {\r",
              "    pm.sendRequest({\r",
              "      url: URL,\r",
              "      method: METHOD,\r",
              "      header: HEADERS,\r",
              "      body: { mode: \"raw\", raw: JSON.stringify(BODY) },\r",
              "      // rejectUnauthorized: false // uncomment if using self-signed certs and needed\r",
              "    }, (err, res) => {\r",
              "      stats.total++;\r",
              "      if (err) {\r",
              "        stats.errors[\"sendError\"] = (stats.errors[\"sendError\"] || 0) + 1;\r",
              "      } else if (res && res.code >= 200 && res.code < 300) {\r",
              "        stats.success++;\r",
              "      } else {\r",
              "        const key = res && res.code ? `http_${res.code}` : \"unknown\";\r",
              "        stats.errors[key] = (stats.errors[key] || 0) + 1;\r",
              "      }\r",
              "      resolve();\r",
              "    });\r",
              "  });\r",
              "}\r",
              "\r",
              "async function worker(id, iterations) {\r",
              "  for (let i = 0; i < iterations; i++) {\r",
              "    // stop once we've reached TOTAL_REQUESTS\r",
              "    if (stats.total >= TOTAL_REQUESTS) break;\r",
              "    await sendOne();\r",
              "  }\r",
              "}\r",
              "\r",
              "(async () => {\r",
              "  const workers = [];\r",
              "  for (let w = 0; w < CONCURRENCY; w++) {\r",
              "    workers.push(worker(w, ITERATIONS));\r",
              "  }\r",
              "  await Promise.all(workers);\r",
              "  const elapsed = Date.now() - stats.start;\r",
              "  console.log(\"Concurrency test finished. elapsed ms:\", elapsed);\r",
              "  console.log(\"total:\", stats.total, \"success:\", stats.success, \"errors:\", stats.errors);\r",
              "  pm.environment.set(\"concurrency_test_summary\", JSON.stringify({ elapsed, ...stats }));\r",
              "})();\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
